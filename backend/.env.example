# ✅ ALREADY IN YOUR .env.local — COPY FROM THERE
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=sk-proj-...
REPLICATE_API_TOKEN=r8_...

# ✅ SET THESE YOURSELF (simple values)
JWT_SECRET=any_long_random_string_here_min_32_chars
ADMIN_EMAIL=admin@socialai.com
ADMIN_PASSWORD=Admin@123456
WHATSAPP_VERIFY_TOKEN=myverifytoken123

# ❌ CLOUDINARY — Sign up FREE at cloudinary.com → Dashboard → Copy these 3
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ❌ WHATSAPP META — From Meta Developers (developers.facebook.com)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ❌ FACEBOOK APP — From Meta Developers (for Instagram token refresh)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# URLs
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-api.railway.app
PORT=5000
NODE_ENV=production
